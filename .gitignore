// ─────────────────────────────────────────
// FREE TEXT PATTERN MATCHING
// ─────────────────────────────────────────
function detectPreset(text) {
  const t = text.toLowerCase();
  if (/cs|カスタマー|問い合わせ|inquiry|サポート|チャット/.test(t)) return 'cs';
  if (/取引|trade|注文|order|株|option|etf|為替/.test(t)) return 'trade';
  if (/コンプラ|compliance|規制|aml|sesc|法令|監査/.test(t)) return 'compliance';
  if (/財務|finance|kpi|経営|報告|レポート|report|集計/.test(t)) return 'finance';
  if (/マーケ|marketing|キャンペーン|sns|広告|コピー/.test(t)) return 'marketing';
  if (/it|セキュリティ|security|インシデント|システム|bcp/.test(t)) return 'it';
  if (/hr|人事|評価|採用|資格|okr/.test(t)) return 'hr';
  return 'generic';
}

function extractSkillName(text) {
  const patterns = [
    /「?(.+?)」?(?:の|を|という)?skill/i,
    /(.+?)(?:skill|スキル)を/i,
    /\/([a-zA-Z0-9-_]+)/,
  ];
  for (const p of patterns) {
    const m = text.match(p);
    if (m) {
      return m[1].trim()
        .replace(/[「」\s]/g, '-')
        .replace(/[^a-zA-Z0-9\-ぁ-ん一-龥]/g, '')
        .toLowerCase()
        .substring(0, 30) || 'my-skill';
    }
  }
  return 'my-skill';
}

function designFromText() {
  const text = document.getElementById('freeInput').value.trim();
  if (!text) { showToast('テキストを入力してください'); return; }
  const preset = detectPreset(text);
  loadPreset(preset);
  const skillName = extractSkillName(text);
  if (skillName && skillName !== 'my-skill') {
    document.getElementById('f_name').value = skillName;
  }
  updatePreview();
  showToast(`「${preset}」テンプレートで設計しました ✓`);
  document.querySelector('.editor-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ─────────────────────────────────────────
// PRESET LOADER
// ─────────────────────────────────────────
function loadPreset(key) {
  const p = PRESETS[key];
  if (!p) return;
  document.getElementById('f_name').value = p.name;
  document.getElementById('f_when').value = p.when;
  document.getElementById('f_what').value = p.what;
  document.getElementById('f_how').value = p.how;
  document.getElementById('f_ref').value = p.ref;
  document.getElementById('f_limits').value = p.limits;

  // Active state on button
  document.querySelectorAll('.dept-btn').forEach(b => b.classList.remove('active'));
  const btn = document.querySelector(`.dept-btn[data-dept="${key}"]`);
  if (btn) btn.classList.add('active');

  updatePreview();
  showToast(`「${key}」プリセットを読み込みました ✓`);
}

// ─────────────────────────────────────────
// PREVIEW GENERATOR
// ─────────────────────────────────────────
function updatePreview() {
  const name   = document.getElementById('f_name').value.trim() || 'my-skill';
  const when   = document.getElementById('f_when').value.trim();
  const what   = document.getElementById('f_what').value.trim();
  const how    = document.getElementById('f_how').value.trim();
  const ref    = document.getElementById('f_ref').value.trim();
  const limits = document.getElementById('f_limits').value.trim();

  // Build description from WHAT (first line)
  const desc = what ? what.split('\n')[0].substring(0, 80) : `${name} Skill`;

  const md = [
    '---',
    `description: "${desc}"`,
    '---',
    '',
    `# /${name}`,
    '',
    '## WHEN — いつ使うか',
    when || '（未入力）',
    '',
    '## WHAT — 何をするか',
    what || '（未入力）',
    '',
    '## HOW — どうやるか',
    how || '（未入力）',
    '',
    '## REFERENCE — 参照情報',
    ref || '（未入力）',
    '',
    '## LIMITS — やらないこと',
    limits || '（未入力）',
  ].join('\n');

  // Syntax-highlighted display
  const highlighted = md
    .replace(/^(---)/gm, '<span class="yaml">---</span>')
    .replace(/^(description:.+)/gm, '<span class="yaml">$1</span>')
    .replace(/^(# .+)/gm, '<span class="heading">$1</span>')
    .replace(/^(## .+)/gm, '<span class="label">$1</span>');

  document.getElementById('previewCode').innerHTML = highlighted;

  // Path hints
  const safeName = name.replace(/[^a-zA-Z0-9\-_]/g, '-');
  document.getElementById('previewPath').textContent = safeName;
  document.getElementById('previewPath2').textContent = safeName;

  // Store for copy/download
  document.getElementById('previewCode').dataset.raw = md;
}

// ─────────────────────────────────────────
// COPY / DOWNLOAD
// ─────────────────────────────────────────
function copyPreview() {
  const raw = document.getElementById('previewCode').dataset.raw || '';
  if (!raw) { showToast('プレビューを生成してください'); return; }
  navigator.clipboard.writeText(raw).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.textContent = '✓ コピー済み';
    btn.classList.add('copied');
    showToast('クリップボードにコピーしました ✓');
    setTimeout(() => {
      btn.textContent = '📋 コピー';
      btn.classList.remove('copied');
    }, 2000);
  }).catch(() => {
    // fallback
    const ta = document.createElement('textarea');
    ta.value = raw;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('コピーしました ✓');
  });
}

function downloadSkill() {
  const raw = document.getElementById('previewCode').dataset.raw || '';
  const name = document.getElementById('f_name').value.trim() || 'my-skill';
  if (!raw) { showToast('プレビューを生成してください'); return; }
  const blob = new Blob([raw], { type: 'text/markdown;charset=utf-8' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `${name}.md`;
  a.click();
  showToast(`${name}.md をダウンロードしました ✓`);
}

// ─────────────────────────────────────────
// MODAL
// ─────────────────────────────────────────
function openModal(el) {
  const d = MODAL_DATA[el];
  if (!d) return;

  document.getElementById('modalTitle').innerHTML =
    `<span style="font-size:1.3rem">${d.icon}</span>
     <span style="color:${d.color}">${d.title}</span>`;

  let html = `
    <div class="modal-section">
      <h4>定義</h4>
      <p>${d.desc}</p>
    </div>
    <div class="modal-section">
      <h4>書き方のコツ</h4>
      <ul style="padding-left:16px;font-size:.83rem;color:#cbd5e1;line-height:2">
        ${d.tips.map(t => `<li>${t}</li>`).join('')}
      </ul>
    </div>
    <div class="modal-section">
      <h4>良い例</h4>
      ${d.good.map(g => `
        <div class="example-label good">✓ GOOD</div>
        <div class="example-good">${g.replace(/\n/g, '<br>')}</div>
      `).join('')}
    </div>
    <div class="modal-section">
      <h4>避けるべき例</h4>
      ${d.bad.map(b => `
        <div class="example-label bad">✗ AVOID</div>
        <div class="example-bad">${b.replace(/\n/g, '<br>')}</div>
      `).join('')}
    </div>
    <button class="modal-use-btn" onclick="focusField('${d.fieldId}');closeModal()">
      ✏️ このフィールドを編集する
    </button>
  `;

  document.getElementById('modalBody').innerHTML = html;
  document.getElementById('modalOverlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
}

function focusField(id) {
  const el = document.getElementById(id);
  if (el) {
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(() => el.focus(), 300);
  }
}

// ─────────────────────────────────────────
// TOAST
// ─────────────────────────────────────────
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
}

// ─────────────────────────────────────────
// KEYBOARD SHORTCUT
// ─────────────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeModal();
});

// ─────────────────────────────────────────
// INIT
// ─────────────────────────────────────────
updatePreview();
</script>
</body>
</html>
