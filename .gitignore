<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Claude Code Skill Designer</title>
<style>
:root {
  --when:   #3b82f6;
  --what:   #10b981;
  --how:    #f59e0b;
  --ref:    #8b5cf6;
  --limits: #ef4444;
  --bg:     #0f172a;
  --surface:#1e293b;
  --border: #334155;
  --text:   #e2e8f0;
  --muted:  #94a3b8;
  --accent: #38bdf8;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;min-height:100vh;overflow-x:hidden}

/* ── HEADER ── */
.header{background:linear-gradient(135deg,#1e3a5f 0%,#1a2744 100%);border-bottom:1px solid var(--border);padding:16px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;backdrop-filter:blur(12px)}
.logo{display:flex;align-items:center;gap:10px;font-size:1.2rem;font-weight:700;color:#fff}
.logo-icon{background:linear-gradient(135deg,var(--accent),#6366f1);border-radius:8px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:1.1rem}
.badge{background:#1d4ed8;color:#bfdbfe;font-size:.65rem;padding:2px 7px;border-radius:99px;font-weight:600;letter-spacing:.05em}

/* ── MAIN ── */
.main{max-width:1200px;margin:0 auto;padding:28px 20px}

/* ── SECTION LABEL ── */
.section-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:12px;font-weight:600;display:flex;align-items:center;gap:6px}
.section-label::after{content:'';flex:1;height:1px;background:var(--border)}

/* ── FRAMEWORK CARDS ── */
.cards-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:28px}
@media(max-width:768px){.cards-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:480px){.cards-grid{grid-template-columns:repeat(2,1fr)}}
.fcard{border-radius:12px;padding:18px 14px;cursor:pointer;transition:transform .15s,box-shadow .15s;border:1px solid transparent;position:relative;overflow:hidden;text-align:center;user-select:none}
.fcard::before{content:'';position:absolute;inset:0;opacity:.12;border-radius:12px}
.fcard:hover{transform:translateY(-3px);box-shadow:0 12px 32px rgba(0,0,0,.4)}
.fcard:active{transform:translateY(0)}
.fcard[data-el="when"]{background:linear-gradient(135deg,#1e3a5f,#1e293b);border-color:var(--when)}
.fcard[data-el="when"]:hover{box-shadow:0 8px 30px rgba(59,130,246,.3)}
.fcard[data-el="what"]{background:linear-gradient(135deg,#064e3b,#1e293b);border-color:var(--what)}
.fcard[data-el="what"]:hover{box-shadow:0 8px 30px rgba(16,185,129,.3)}
.fcard[data-el="how"]{background:linear-gradient(135deg,#451a03,#1e293b);border-color:var(--how)}
.fcard[data-el="how"]:hover{box-shadow:0 8px 30px rgba(245,158,11,.3)}
.fcard[data-el="ref"]{background:linear-gradient(135deg,#2e1065,#1e293b);border-color:var(--ref)}
.fcard[data-el="ref"]:hover{box-shadow:0 8px 30px rgba(139,92,246,.3)}
.fcard[data-el="limits"]{background:linear-gradient(135deg,#450a0a,#1e293b);border-color:var(--limits)}
.fcard[data-el="limits"]:hover{box-shadow:0 8px 30px rgba(239,68,68,.3)}
.fcard-icon{font-size:1.8rem;margin-bottom:8px}
.fcard-title{font-size:.8rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px}
.fcard-sub{font-size:.68rem;color:var(--muted);line-height:1.4}
.fcard[data-el="when"] .fcard-title{color:var(--when)}
.fcard[data-el="what"] .fcard-title{color:var(--what)}
.fcard[data-el="how"] .fcard-title{color:var(--how)}
.fcard[data-el="ref"] .fcard-title{color:var(--ref)}
.fcard[data-el="limits"] .fcard-title{color:var(--limits)}
.click-hint{position:absolute;bottom:6px;right:8px;font-size:.58rem;color:var(--muted);opacity:.7}

/* ── DEPT BUTTONS ── */
.dept-grid{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px}
.dept-btn{padding:8px 16px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--text);cursor:pointer;font-size:.8rem;font-weight:500;transition:all .15s;display:flex;align-items:center;gap:6px}
.dept-btn:hover{background:#334155;border-color:var(--accent);color:var(--accent)}
.dept-btn.active{background:#1d4ed8;border-color:#3b82f6;color:#fff}

/* ── FREE INPUT ── */
.free-input-wrap{display:flex;gap:10px;margin-bottom:28px}
.free-input{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px 16px;color:var(--text);font-size:.9rem;outline:none;transition:border-color .15s}
.free-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(56,189,248,.15)}
.free-input::placeholder{color:var(--muted)}
.design-btn{background:linear-gradient(135deg,#1d4ed8,#6366f1);color:#fff;border:none;border-radius:10px;padding:12px 22px;font-size:.85rem;font-weight:600;cursor:pointer;white-space:nowrap;transition:opacity .15s}
.design-btn:hover{opacity:.9}

/* ── EDITOR + PREVIEW ── */
.editor-row{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:900px){.editor-row{grid-template-columns:1fr}}
.editor-panel,.preview-panel{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:20px}
.panel-title{font-size:.8rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:16px;display:flex;align-items:center;gap:8px}

/* Fields */
.field-group{margin-bottom:14px}
.field-label{display:flex;align-items:center;gap:8px;font-size:.75rem;font-weight:700;margin-bottom:5px;text-transform:uppercase;letter-spacing:.07em}
.field-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.dot-when{background:var(--when)}
.dot-what{background:var(--what)}
.dot-how{background:var(--how)}
.dot-ref{background:var(--ref)}
.dot-limits{background:var(--limits)}
.field-label span{color:var(--muted);font-weight:400;font-size:.7rem;text-transform:none;letter-spacing:0;margin-left:4px}
textarea,input[type=text]{width:100%;background:#0f172a;border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-size:.82rem;line-height:1.6;outline:none;resize:vertical;transition:border-color .15s;font-family:inherit}
textarea:focus,input[type=text]:focus{border-color:var(--accent)}
textarea[data-el="when"]:focus{border-color:var(--when)}
textarea[data-el="what"]:focus{border-color:var(--what)}
textarea[data-el="how"]:focus{border-color:var(--how)}
textarea[data-el="ref"]:focus{border-color:var(--ref)}
textarea[data-el="limits"]:focus{border-color:var(--limits)}
.name-row{display:grid;grid-template-columns:1fr auto;gap:10px;margin-top:16px;align-items:end}
.generate-btn{background:linear-gradient(135deg,#10b981,#059669);color:#fff;border:none;border-radius:8px;padding:10px 18px;font-size:.82rem;font-weight:600;cursor:pointer;white-space:nowrap;transition:opacity .15s}
.generate-btn:hover{opacity:.9}

/* Preview */
.preview-code{background:#0a0f1a;border:1px solid #1e3a5f;border-radius:8px;padding:14px;font-family:'Cascadia Code','Consolas',monospace;font-size:.72rem;line-height:1.7;color:#94a3b8;white-space:pre-wrap;word-break:break-word;min-height:220px;max-height:380px;overflow-y:auto}
.preview-code .yaml{color:#93c5fd}
.preview-code .heading{color:#6ee7b7;font-weight:bold}
.preview-code .label{color:#fbbf24}
.preview-code .value{color:#e2e8f0}
.preview-actions{display:flex;gap:8px;margin-top:12px}
.copy-btn,.dl-btn{padding:8px 14px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;font-size:.76rem;transition:all .15s;display:flex;align-items:center;gap:5px}
.copy-btn:hover{background:#334155;color:#fff;border-color:#64748b}
.copy-btn.copied{background:#064e3b;border-color:#10b981;color:#6ee7b7}
.dl-btn:hover{background:#334155;color:#fff;border-color:#64748b}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);display:none;align-items:center;justify-content:center;z-index:999;padding:20px;backdrop-filter:blur(4px)}
.modal-overlay.open{display:flex}
.modal{background:#1e293b;border-radius:16px;max-width:580px;width:100%;border:1px solid var(--border);box-shadow:0 24px 60px rgba(0,0,0,.6);overflow:hidden;animation:modalIn .2s ease}
@keyframes modalIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
.modal-header{padding:20px 22px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.modal-title{font-size:1rem;font-weight:700;display:flex;align-items:center;gap:10px}
.modal-close{background:none;border:none;color:var(--muted);cursor:pointer;font-size:1.3rem;padding:0;line-height:1;transition:color .15s}
.modal-close:hover{color:var(--text)}
.modal-body{padding:20px 22px;max-height:60vh;overflow-y:auto}
.modal-section{margin-bottom:18px}
.modal-section h4{font-size:.75rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:8px;font-weight:600}
.modal-section p{font-size:.85rem;line-height:1.7;color:#cbd5e1}
.example-good,.example-bad{border-radius:8px;padding:10px 12px;font-size:.78rem;line-height:1.6;margin-bottom:6px;font-family:'Cascadia Code','Consolas',monospace}
.example-good{background:#052e16;border-left:3px solid #10b981;color:#86efac}
.example-bad{background:#450a0a;border-left:3px solid #ef4444;color:#fca5a5}
.example-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;font-weight:700;margin-bottom:4px;font-family:'Segoe UI',sans-serif}
.example-label.good{color:#10b981}
.example-label.bad{color:#ef4444}
.modal-use-btn{width:100%;padding:10px;background:linear-gradient(135deg,#1d4ed8,#6366f1);border:none;border-radius:8px;color:#fff;font-size:.82rem;font-weight:600;cursor:pointer;margin-top:6px;transition:opacity .15s}
.modal-use-btn:hover{opacity:.9}

/* ── TOAST ── */
.toast{position:fixed;bottom:24px;right:24px;background:#1e3a5f;border:1px solid #3b82f6;color:#bfdbfe;padding:10px 18px;border-radius:8px;font-size:.8rem;transform:translateY(80px);transition:transform .25s;z-index:9999;pointer-events:none}
.toast.show{transform:translateY(0)}
</style>
</head>
<body>

<!-- HEADER -->
<header class="header">
  <div class="logo">
    <div class="logo-icon">🛠</div>
    <span>Claude Code Skill Designer</span>
    <span class="badge">BETA</span>
  </div>
  <div style="font-size:.7rem;color:var(--muted)">5要素フレームワークでSkillを設計</div>
</header>

<!-- MAIN -->
<main class="main">

  <!-- 5-ELEMENT CARDS -->
  <div class="section-label">5要素フレームワーク — クリックして詳細を見る</div>
  <div class="cards-grid">
    <div class="fcard" data-el="when" onclick="openModal('when')">
      <div class="fcard-icon">⏰</div>
      <div class="fcard-title">WHEN</div>
      <div class="fcard-sub">いつ使う？<br>トリガー条件</div>
      <div class="click-hint">▶ 詳細</div>
    </div>
    <div class="fcard" data-el="what" onclick="openModal('what')">
      <div class="fcard-icon">🎯</div>
      <div class="fcard-title">WHAT</div>
      <div class="fcard-sub">何をする？<br>目的・成果物</div>
      <div class="click-hint">▶ 詳細</div>
    </div>
    <div class="fcard" data-el="how" onclick="openModal('how')">
      <div class="fcard-icon">⚙️</div>
      <div class="fcard-title">HOW</div>
      <div class="fcard-sub">どうやる？<br>実行ステップ</div>
      <div class="click-hint">▶ 詳細</div>
    </div>
    <div class="fcard" data-el="ref" onclick="openModal('ref')">
      <div class="fcard-icon">📚</div>
      <div class="fcard-title">REFERENCE</div>
      <div class="fcard-sub">何を参照？<br>ファイル・知識</div>
      <div class="click-hint">▶ 詳細</div>
    </div>
    <div class="fcard" data-el="limits" onclick="openModal('limits')">
      <div class="fcard-icon">🚧</div>
      <div class="fcard-title">LIMITS</div>
      <div class="fcard-sub">やらないこと<br>制限・注意</div>
      <div class="click-hint">▶ 詳細</div>
    </div>
  </div>

  <!-- DEPT PRESETS -->
  <div class="section-label">部門プリセット — クリックで即テンプレート生成</div>
  <div class="dept-grid" id="deptGrid">
    <button class="dept-btn" data-dept="cs" onclick="loadPreset('cs')">🎧 カスタマーサポート</button>
    <button class="dept-btn" data-dept="trade" onclick="loadPreset('trade')">📈 取引・商品</button>
    <button class="dept-btn" data-dept="compliance" onclick="loadPreset('compliance')">⚖️ コンプライアンス</button>
    <button class="dept-btn" data-dept="finance" onclick="loadPreset('finance')">💰 財務・経営管理</button>
    <button class="dept-btn" data-dept="marketing" onclick="loadPreset('marketing')">📣 マーケティング</button>
    <button class="dept-btn" data-dept="it" onclick="loadPreset('it')">🔒 IT・セキュリティ</button>
    <button class="dept-btn" data-dept="hr" onclick="loadPreset('hr')">👥 HR・人事</button>
    <button class="dept-btn" data-dept="generic" onclick="loadPreset('generic')">✨ 汎用テンプレート</button>
  </div>

  <!-- FREE INPUT -->
  <div class="section-label">自由入力 — 作りたいSkillを一文で</div>
  <div class="free-input-wrap">
    <input type="text" class="free-input" id="freeInput"
      placeholder="例：「顧客からの入金エラー問い合わせに対応するSkillを設計して」「週次レポートを自動生成するSkillを作りたい」"
      onkeydown="if(event.key==='Enter')designFromText()">
    <button class="design-btn" onclick="designFromText()">✦ 設計する</button>
  </div>

  <!-- EDITOR + PREVIEW -->
  <div class="section-label">Skillエディター</div>
  <div class="editor-row">

    <!-- EDITOR -->
    <div class="editor-panel">
      <div class="panel-title">✏️ &nbsp;5要素を記入</div>

      <div class="field-group">
        <div class="field-label">
          <div class="field-dot dot-when"></div>
          <span style="color:var(--when)">WHEN</span>
          <span>— いつ使うか（トリガー条件）</span>
        </div>
        <textarea id="f_when" data-el="when" rows="3"
          placeholder="例：ユーザーが /cs-escalate と入力したとき&#10;問い合わせをエスカレーションすべきか判断が必要なとき"
          oninput="updatePreview()"></textarea>
      </div>

      <div class="field-group">
        <div class="field-label">
          <div class="field-dot dot-what"></div>
          <span style="color:var(--what)">WHAT</span>
          <span>— 何をするか（成果物）</span>
        </div>
        <textarea id="f_what" data-el="what" rows="3"
          placeholder="例：顧客問い合わせの緊急度・複雑度を判定し、エスカレーション先と理由を提示する&#10;出力：判定レポート（Markdownテキスト）"
          oninput="updatePreview()"></textarea>
      </div>

      <div class="field-group">
        <div class="field-label">
          <div class="field-dot dot-how"></div>
          <span style="color:var(--how)">HOW</span>
          <span>— どうやるか（実行ステップ）</span>
        </div>
        <textarea id="f_how" data-el="how" rows="4"
          placeholder="例：1. 問い合わせ内容のカテゴリを判定（入金/取引/コンプラ/その他）&#10;2. 緊急度スコアを算出（キーワードマッチ＋件数）&#10;3. エスカレーション先チームを判定&#10;4. 対応推奨メッセージを生成"
          oninput="updatePreview()"></textarea>
      </div>

      <div class="field-group">
        <div class="field-label">
          <div class="field-dot dot-ref"></div>
          <span style="color:var(--ref)">REFERENCE</span>
          <span>— 参照する情報・ファイル</span>
        </div>
        <textarea id="f_ref" data-el="ref" rows="3"
          placeholder="例：・社内エスカレーションフロー図（SOP）&#10;・過去対応履歴CSV&#10;・各チームのSlack/Teamsチャンネル一覧"
          oninput="updatePreview()"></textarea>
      </div>

      <div class="field-group">
        <div class="field-label">
          <div class="field-dot dot-limits"></div>
          <span style="color:var(--limits)">LIMITS</span>
          <span>— やらないこと・制限事項</span>
        </div>
        <textarea id="f_limits" data-el="limits" rows="3"
          placeholder="例：・顧客への直接返信はしない（提案のみ）&#10;・個人情報（口座番号・マイナンバー）を出力しない&#10;・法的判断は行わない"
          oninput="updatePreview()"></textarea>
      </div>

      <div class="name-row">
        <div>
          <div class="field-label" style="margin-bottom:5px">
            <span style="color:var(--muted)">SKILL名（/コマンド名）</span>
          </div>
          <input type="text" id="f_name" placeholder="例：cs-escalate" oninput="updatePreview()"
            style="height:40px">
        </div>
        <button class="generate-btn" onclick="updatePreview()">▶ プレビュー更新</button>
      </div>
    </div>

    <!-- PREVIEW -->
    <div class="preview-panel">
      <div class="panel-title">👁️ &nbsp;出力プレビュー (.md)</div>
      <div class="preview-code" id="previewCode"></div>
      <div class="preview-actions">
        <button class="copy-btn" id="copyBtn" onclick="copyPreview()">📋 コピー</button>
        <button class="dl-btn" onclick="downloadSkill()">⬇ .md ダウンロード</button>
      </div>
      <div style="margin-top:14px;padding:12px;background:#0f172a;border-radius:8px;border:1px solid var(--border)">
        <div style="font-size:.68rem;color:var(--muted);margin-bottom:8px;font-weight:600;text-transform:uppercase;letter-spacing:.07em">📂 保存先（Claude Code）</div>
        <div style="font-size:.72rem;color:#94a3b8;font-family:monospace;line-height:1.8">
          Windows: <span style="color:#bfdbfe">%USERPROFILE%\.claude\skills\<span id="previewPath">skill-name</span>.md</span><br>
          Mac/Linux: <span style="color:#bfdbfe">~/.claude/skills/<span id="previewPath2">skill-name</span>.md</span>
        </div>
      </div>
    </div>
  </div>

</main>

<!-- MODAL -->
<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="modalTitle"></div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body" id="modalBody"></div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ─────────────────────────────────────────
// MODAL DATA
// ─────────────────────────────────────────
const MODAL_DATA = {
  when: {
    color: 'var(--when)',
    icon: '⏰',
    title: 'WHEN — いつ使うか',
    desc: 'ユーザーがこのSkillを呼ぶべき状況・トリガー条件を定義します。「/コマンド名」を入力したとき、または「○○の作業を始めたとき」のように、Claudeが自動的にSkillを提案するケースを指定します。',
    tips: [
      'コマンド名は短く・直感的に（例：/review, /report）',
      '「〜するとき」「〜が必要なとき」という形式で書く',
      '1つのSkillに2〜3個のトリガー条件で十分',
    ],
    good: [
      '/cs-report を入力したとき',
      'CS管理者が週次問い合わせ集計を依頼するとき',
      '入金エラーの根本原因を分析したいとき',
    ],
    bad: [
      '何かするとき（曖昧すぎ）',
      'いつでも使えます（トリガーが不明確）',
    ],
    fieldId: 'f_when',
  },
  what: {
    color: 'var(--what)',
    icon: '🎯',
    title: 'WHAT — 何をするか',
    desc: 'このSkillが実行した結果として何が得られるか（成果物・アウトプット）を明確にします。「Markdownレポートを生成する」「分析結果をテーブルで出力する」のように、具体的な成果物形式を書きましょう。',
    tips: [
      '「〜を生成する」「〜を出力する」という動詞で終える',
      '成果物のフォーマット（Markdown/テーブル/箇条書き）を明示',
      '1 Skill = 1目的が理想。複数の目的は別Skillに分割',
    ],
    good: [
      '週次CS問い合わせデータをカテゴリ別に集計し、Markdownレポートを生成する',
      '入金エラーの原因カテゴリと発生件数テーブルを出力する',
    ],
    bad: [
      'いろいろ分析する（範囲が不明確）',
      'CS業務を助ける（成果物が不明）',
    ],
    fieldId: 'f_what',
  },
  how: {
    color: 'var(--how)',
    icon: '⚙️',
    title: 'HOW — どうやるか',
